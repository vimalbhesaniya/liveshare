# ─── Server ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/liveshare
PORT=3001
CLIENT_ORIGIN=http://localhost:8080
SERVE_FRONTEND=false

# ─── Frontend → Backend ───────────────────────────────────────────────
# Dev: leave empty (Vite proxies /api and /socket.io to PORT)
# Prod (same domain): leave empty
# After `npm run deploy` — paste URLs from deploy output
VITE_BACKEND_URL=
VITE_WS_URL=

# Local dev only (leave VITE_WS_URL empty — uses Socket.io via Vite proxy)
VITE_API_URL=
VITE_SOCKET_URL=

# ─── EmailJS ──────────────────────────────────────────────────────────
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ─── Maintenance ──────────────────────────────────────────────────────
VITE_MAINTENANCE_MODE=false
VITE_MAINTENANCE_MESSAGE="We're doing some improvements right now. Please check back in a bit."
